          <p class="font-['Cormorant_Garamond'] text-xl text-[#1a1208]">+51 925 482 618</p>
        </div>
        <div class="bg-[#f5f0e8] p-10 text-center hover:bg-[#c9a84c]/5 transition-colors duration-300">
          <div class="text-3xl mb-4">✉️</div>
