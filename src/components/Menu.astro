---
const categorias = [
  {
    nombre: "Desayunos",
    subtitulo: "Para comenzar el día",
    emoji: "☀️",
    imagen: "/images/desayuno.jpg",
    platillos: [
      { nombre: "Pan con chicharrón", desc: "Pan crujiente con chicharrón dorado", precio: "S/ 4.00" },
      { nombre: "Tamal", desc: "Tamal tradicional de maíz", precio: "S/ 2.00" },
      { nombre: "Humita", desc: "Humita dulce de choclo fresco", precio: "S/ 2.00" },
    ],
  },
  {
    nombre: "Almuerzos",
    subtitulo: "El corazón de nuestra cocina",
    emoji: "🍽️",
    imagen: "/images/almuerzo.jpg",
    platillos: [
      { nombre: "Ceviche", desc: "Pescado fresco marinado en limón", precio: "S/ 6.00" },
      { nombre: "Lomo saltado", desc: "Lomo de res salteado con verduras", precio: "S/ 7.00" },
      { nombre: "Ají de gallina", desc: "Pollo deshilachado en salsa de ají amarillo", precio: "S/ 6.00" },
    ],
  },
  {
    nombre: "Cenas",
    subtitulo: "Para cerrar el día con sabor",
    emoji: "🌙",
    imagen: "/images/cena.jpg",
    platillos: [
      { nombre: "Anticuchos", desc: "Corazón de res a la parrilla", precio: "S/ 2.00" },
      { nombre: "Pollo a la brasa", desc: "Pollo entero con papas fritas", precio: "S/ 45.00" },
      { nombre: "Salchipollo", desc: "Salchipapas con pollo frito", precio: "S/ 6.00" },
    ],
  },
];

const postres = [
  { nombre: "Arroz con leche",   desc: "Cremoso y canela", precio: "S/ 3.00", imagen: "/images/arroz_leche.png" },
  { nombre: "Mazamorra morada",  desc: "Postre tradicional peruano", precio: "S/ 3.00", imagen: "/images/mazamorra.png" },
  { nombre: "Arroz zambito",     desc: "Con chancaca y coco rallado", precio: "S/ 4.00", imagen: "/images/arroz_zambito.png" },
];
---

<section id="menu" class="relative py-24 px-4 md:px-6">
  <div class="max-w-4xl mx-auto">

    <!-- Header sección -->
    <div class="text-center mb-20">
      <p class="font-['DM_Sans'] text-xs tracking-[0.5em] uppercase text-[#c9a84c] mb-4">✦ Nuestra carta ✦</p>
      <h2 class="font-['Cormorant_Garamond'] text-6xl md:text-8xl font-light text-[#1a1208] mb-4">Menú</h2>
      <div class="ornament w-64 mx-auto">
        <span class="font-['Cormorant_Garamond'] text-[#c9a84c]">✦</span>
      </div>
    </div>

    <!-- Categorías -->
    {categorias.map((cat, i) => (
      <div class="mb-20">
        <!-- Título categoría -->
        <div class="text-center mb-10">
          <span class="text-3xl mb-3 block">{cat.emoji}</span>
          <h3 class="font-['Cormorant_Garamond'] text-4xl md:text-5xl font-light text-[#1a1208]">{cat.nombre}</h3>
          <p class="font-['DM_Sans'] text-xs tracking-widest uppercase text-[#c9a84c]/70 mt-2">{cat.subtitulo}</p>
          <div class="h-px w-16 bg-[#c9a84c]/30 mx-auto mt-4"></div>
        </div>

        <!-- Layout imagen + platillos -->
        <div class={`flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-8 items-stretch`}>

          <!-- Imagen -->
          <div class="w-full md:w-2/5 overflow-hidden">
            <div class="relative h-64 md:h-full min-h-70 overflow-hidden group">
              <img
                src={cat.imagen}
                alt={cat.nombre}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <!-- Overlay dorado sutil -->
              <div class="absolute inset-0 bg-gradient-to from-[#1a1208]/40 to-transparent"></div>
              <span class="absolute bottom-4 left-4 font-['Cormorant_Garamond'] text-2xl text-[#e8c97a] italic">{cat.nombre}</span>
            </div>
          </div>

          <!-- Platillos -->
          <div class="w-full md:w-3/5 flex flex-col justify-center gap-0 border border-[#c9a84c]/15">
            {cat.platillos.map((p, j) => (
              <div class={`flex justify-between items-start p-5 group hover:bg-[#c9a84c]/5 transition-colors duration-200 ${j < cat.platillos.length - 1 ? 'border-b border-[#c9a84c]/10' : ''}`}>
                <div class="flex-1 pr-4">
                  <p class="font-['Cormorant_Garamond'] text-xl text-[#1a1208] group-hover:text-[#c9a84c] transition-colors duration-200">{p.nombre}</p>
                  <p class="font-['DM_Sans'] text-xs text-[#3d2b1f]/40 mt-1 leading-relaxed">{p.desc}</p>
                </div>
                <span class="font-['Cormorant_Garamond'] text-xl text-[#c9a84c] whitespace-nowrap">{p.precio}</span>
              </div>
            ))}
          </div>

        </div>
      </div>
    ))}

    <!-- Divisor ornamental -->
    <div class="text-center my-20">
      <div class="ornament w-full mx-auto">
        <span class="font-['Cormorant_Garamond'] text-[#c9a84c] text-2xl tracking-widest">✦ ✦ ✦</span>
      </div>
    </div>

    <!-- Postres -->
    <div class="text-center mb-12">
      <p class="font-['DM_Sans'] text-xs tracking-[0.5em] uppercase text-[#c9a84c] mb-4">✦ Para endulzar ✦</p>
      <h3 class="font-['Cormorant_Garamond'] text-5xl md:text-6xl font-light text-[#1a1208]">Postres</h3>
      <div class="h-px w-16 bg-[#c9a84c]/30 mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {postres.map(p => (
        <div class="group border border-[#c9a84c]/15 overflow-hidden hover:border-[#c9a84c]/40 transition-colors duration-300">
          <div class="aspect-square overflow-hidden relative">
            <img
              src={p.imagen}
              alt={p.nombre}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to from-[#1a1208]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <div class="p-5 bg-white/30">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-['Cormorant_Garamond'] text-xl text-[#1a1208]">{p.nombre}</p>
                <p class="font-['DM_Sans'] text-xs text-[#3d2b1f]/40 mt-1">{p.desc}</p>
              </div>
              <span class="font-['Cormorant_Garamond'] text-xl text-[#c9a84c]">{p.precio}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>