---
---
<section id="inicio" class="relative min-h-screen flex flex-col justify-center items-center text-center px-6 pt-20 overflow-hidden">

    <!-- Círculo decorativo de fondo -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-150 h-150 rounded-full border border-[#c9a84c]/10 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-100 h-100 rounded-full border border-[#c9a84c]/15 pointer-events-none"></div>
  
    <p class="fade-up fade-up-delay-1 font-['DM_Sans'] text-xs tracking-[0.5em] uppercase text-[#c9a84c] mb-4">
      ✦ Lambayeque, Perú ✦
    </p>
  
    <h1 class="fade-up fade-up-delay-2 font-['Cormorant_Garamond'] text-7xl md:text-[9rem] font-light leading-[0.9] text-[#1a1208] mb-6">
      El<br/><em class="text-[#c9a84c] not-italic">Buen</em><br/>Sabor
    </h1>
  
    <div class="fade-up fade-up-delay-3 ornament w-48 my-6">
      <span class="font-['Cormorant_Garamond'] text-[#c9a84c] text-lg">✦</span>
    </div>
  
    <p class="fade-up fade-up-delay-3 font-['DM_Sans'] text-sm text-[#3d2b1f]/50 tracking-widest uppercase mb-10 max-w-xs leading-relaxed">
      Platillos auténticos de toda la región con el sabor de siempre
    </p>
  
    <div class="fade-up fade-up-delay-4 flex flex-col sm:flex-row gap-4 items-center">
      <a href="#menu" class="font-['DM_Sans'] text-xs tracking-widest uppercase bg-[#1a1208] text-[#f5f0e8] px-10 py-4 hover:bg-[#c9a84c] transition-all duration-300">
        Ver menú
      </a>
      <a href="#contacto" class="font-['DM_Sans'] text-xs tracking-widest uppercase border border-[#c9a84c]/40 text-[#c9a84c] px-10 py-4 hover:border-[#c9a84c] transition-all duration-300">
        Contacto
      </a>
    </div>
  
    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
      <span class="font-['DM_Sans'] text-[10px] tracking-[0.3em] uppercase text-[#3d2b1f]">Scroll</span>
      <div style="width:1px; height:40px; background: linear-gradient(to bottom, #c9a84c, transparent);"></div>

    </div>
  </section>